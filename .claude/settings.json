{
  "autocompact_percentage_override": 75,
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "permissions": {
    "allow": [
      "Bash(python3 -c ':*)",
      "Bash(git commit -m ':*)",
      "Bash(git log *)",
      "Bash(mkdir -p ~/.claude/logs/project-update)",
      "mcp__Linear__list_projects",
      "mcp__Linear__get_status_updates",
      "mcp__Linear__list_issues",
      "mcp__Linear__get_issue",
      "mcp__Linear__save_status_update",
      "mcp__Linear__get_project",
      "Write(~/.claude/logs/project-update/*)"
    ],
    "deny": [
      "Read(./.venv/**)",
      "Read(./node_modules/**)",
      "Read(./__pycache__/**)",
      "Read(**/__pycache__/**)",
      "Read(**/*.egg-info/**)",
      "Read(./.lighthouseci/**)",
      "Read(./logs/**)",
      "Read(./static/css/output.css)",
      "Read(./.tox/**)",
      "Read(./htmlcov/**)",
      "Read(./.pytest_cache/**)",
      "Read(./.ruff_cache/**)",
      "Read(./.mypy_cache/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bin/init-worktree 2>&1 || true"
          }
        ]
      }
    ]
  }
}
