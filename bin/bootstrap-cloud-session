#!/usr/bin/env bash
set -euo pipefail
export DJANGO_SETTINGS_MODULE=config.settings.development

# ensure this only runs in a Cloud environment
[ "${CLAUDE_CODE_REMOTE:-}" = "true" ] || exit 0

# 1. migrations
poetry run python manage.py migrate --no-input

# 2. fixtures (reference data that local-mirror depends on)
poetry run python manage.py loaddata \
  pipeline/fixtures/eaws_major_regions.json \
  pipeline/fixtures/eaws_sub_regions.json \
  pipeline/fixtures/regions.json \
  pipeline/fixtures/resorts.json \


# 3. dev server, detached and surviving the hook's subshell.
# Skip if something is already listening on :8000 (resume case).
if ! curl -fsS http://127.0.0.1:8000/ -o /dev/null 2>&1; then
  mkdir -p logs
  nohup poetry run python manage.py runserver 127.0.0.1:8000 \
    > logs/devserver.log 2>&1 &
  disown
fi

# wait for it to bind (don't poll forever)
for i in {1..30}; do
  curl -fsS http://127.0.0.1:8000/ -o /dev/null && break
  sleep 1
done

# 4. fetch via the local mirror
poetry run python manage.py fetch_bulletins --source local-mirror --commit
