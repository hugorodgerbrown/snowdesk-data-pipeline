#!/usr/bin/env node
/*
 * bin/build-pwa-icons — Render PWA icon PNGs from static/favicon.svg.
 *
 * Outputs four files into static/icons/pwa/:
 *   - icon-192.png            (192×192, purpose: any)
 *   - icon-512.png            (512×512, purpose: any)
 *   - icon-maskable-512.png   (512×512, purpose: maskable)
 *   - apple-touch-icon-180.png (180×180, opaque background, no alpha —
 *                               iOS rounds the corners automatically and
 *                               can't render transparency in home-screen
 *                               icons cleanly)
 *
 * Run via ``npm run build:icons`` (see package.json). The PNGs are
 * checked in alongside ``static/favicon.svg`` — when the SVG changes,
 * regenerate and commit the new outputs.
 *
 * The maskable variant pads the source artwork inside a "safe zone"
 * (80% of the canvas) so adaptive icon shapes on Android don't crop
 * the glyph. The canvas is filled with MASKABLE_CANVAS_COLOUR (the
 * brand green, #2d4a3e) rather than the manifest background_color
 * (cream, #f4f1e8). Without this, Android's circular crop clips into
 * the cream padding at the cardinal edges and shows a visible cream
 * border against the launcher background — the green-on-green canvas
 * ensures those clipped areas are indistinguishable from the icon's own
 * green rect (SNOW-151). The apple-touch-icon and purpose:any variants
 * are unaffected and continue to use BACKGROUND_COLOUR (cream). The
 * maskable PNG must be opaque (no alpha channel) — Android's adaptive-
 * icon mask leaks transparency at the masked corners if the PNG retains
 * an alpha channel, causing the logo to appear shrunken on a white
 * background. ``flatten`` composites transparent pixels onto the
 * supplied background colour; ``removeAlpha`` then drops the alpha
 * channel so the PNG encoder writes RGB (color_type 2) not RGBA
 * (color_type 6). Both steps are required under sharp >= 0.33 —
 * ``flatten`` alone no longer drops the channel. The apple-touch-icon
 * variant uses the same two-step sequence so the icon reads as a solid
 * tile under iOS's automatic corner rounding.
 */

'use strict';

const fs = require('node:fs');
const path = require('node:path');
const sharp = require('sharp');

const REPO_ROOT = path.resolve(__dirname, '..');
const SRC_SVG = path.join(REPO_ROOT, 'static', 'favicon.svg');
const OUT_DIR = path.join(REPO_ROOT, 'static', 'icons', 'pwa');

// Manifest background_color — used as the padding fill for the
// apple-touch-icon and purpose:any variants so the icon reads as a
// solid tile. Keep in sync with static/manifest.webmanifest.
const BACKGROUND_COLOUR = '#f4f1e8';

// Brand green — must match the rect fill in static/favicon.svg.
// Used as the maskable canvas fill so Android's circular crop clips
// green-on-green and shows no cream border (SNOW-151).
const MASKABLE_CANVAS_COLOUR = '#2d4a3e';

const SAFE_ZONE_RATIO = 0.8;

async function buildAny(size, outName) {
  const outPath = path.join(OUT_DIR, outName);
  await sharp(SRC_SVG).resize(size, size).png().toFile(outPath);
  console.log(`wrote ${path.relative(REPO_ROOT, outPath)} (${size}×${size}, any)`);
}

async function buildMaskable(size, outName) {
  const outPath = path.join(OUT_DIR, outName);
  const inner = Math.round(size * SAFE_ZONE_RATIO);
  const pad = Math.round((size - inner) / 2);
  const innerBuffer = await sharp(SRC_SVG).resize(inner, inner).png().toBuffer();
  await sharp({
    create: {
      width: size,
      height: size,
      channels: 4,
      background: MASKABLE_CANVAS_COLOUR,
    },
  })
    .composite([{ input: innerBuffer, top: pad, left: pad }])
    // Flatten fills transparent areas with the canvas colour, then
    // removeAlpha drops the alpha channel entirely so the PNG is written
    // as RGB (color_type 2) not RGBA (color_type 6). Both steps are needed:
    // flatten alone doesn't drop the channel in sharp >= 0.33; removeAlpha
    // alone would fill with black. Together they ensure Android's adaptive-
    // icon mask doesn't leak transparency at the masked corners (SNOW-150).
    .flatten({ background: MASKABLE_CANVAS_COLOUR })
    .removeAlpha()
    .png()
    .toFile(outPath);
  console.log(
    `wrote ${path.relative(REPO_ROOT, outPath)} (${size}×${size}, maskable, ${SAFE_ZONE_RATIO * 100}% safe zone)`,
  );
}

async function buildAppleTouchIcon(size, outName) {
  const outPath = path.join(OUT_DIR, outName);
  // iOS home-screen icons cannot be transparent — flatten the SVG over
  // the manifest background colour so corners don't render black after
  // iOS's automatic corner rounding. ``flatten`` composites transparent
  // pixels onto the background; ``removeAlpha`` then drops the alpha
  // channel so the PNG is written as opaque RGB (color_type 2). Both
  // steps are required under sharp >= 0.33 (see buildMaskable).
  await sharp(SRC_SVG)
    .resize(size, size)
    .flatten({ background: BACKGROUND_COLOUR })
    .removeAlpha()
    .png()
    .toFile(outPath);
  console.log(
    `wrote ${path.relative(REPO_ROOT, outPath)} (${size}×${size}, apple-touch, opaque)`,
  );
}

async function main() {
  if (!fs.existsSync(SRC_SVG)) {
    console.error(`source SVG not found: ${SRC_SVG}`);
    process.exit(1);
  }
  fs.mkdirSync(OUT_DIR, { recursive: true });
  await buildAny(192, 'icon-192.png');
  await buildAny(512, 'icon-512.png');
  await buildMaskable(512, 'icon-maskable-512.png');
  await buildAppleTouchIcon(180, 'apple-touch-icon-180.png');
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
