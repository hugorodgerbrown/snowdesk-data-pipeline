{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "DJANGO_SETTINGS_MODULE=config.settings.perf poetry run python manage.py runserver --noreload 8765",
      "startServerReadyPattern": "Starting development server at",
      "startServerReadyTimeout": 10000,
      "url": [
        "http://localhost:8765/",
        "http://localhost:8765/examples/random/"
      ]
    },
    "assert": {
      "includePassedAssertions": true,
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
